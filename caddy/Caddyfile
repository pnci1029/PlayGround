# SaleHero 프론트엔드 서빙
salehero.kr, www.salehero.kr {
	# SSL 인증서 자동 발급
	
	# API 요청은 백엔드로
	handle /api/* {
		reverse_proxy salehero-container:8880 {
			fail_duration 10s
			max_fails 3
		}
	}
	
	# 정적 파일 서빙 (프론트엔드)
	handle {
		root * /usr/share/nginx/html
		file_server
		try_files {path} /index.html
	}
}

# SaleHero n8n 서브도메인
n8n.salehero.kr {
	# SSL 인증서 자동 발급
	
	# n8n 웹 인터페이스
	reverse_proxy n8n:5678 {
		fail_duration 10s
		max_fails 3
	}
}

# Blog 도메인 - 프론트엔드는 Vercel, API는 백엔드
blog.chhong.kr {
	# SSL 인증서 자동 발급
	
	# API 요청
	handle /api/* {
		reverse_proxy blog:8003 {
			fail_duration 10s
			max_fails 3
		}
	}

	# WebSocket 요청
	handle /ws {
		reverse_proxy blog:8013 {
			header_up Upgrade {http.request.header.Upgrade}
			header_up Connection {http.request.header.Connection}
			header_up Sec-WebSocket-Key {http.request.header.Sec-WebSocket-Key}
			header_up Sec-WebSocket-Version {http.request.header.Sec-WebSocket-Version}
		}
	}

	# Health check
	handle /health {
		reverse_proxy blog:8003
	}
	
	# 프론트엔드는 Vercel에서 처리
	respond "Blog Frontend at Vercel" 404
}

# Stock Screener 서브도메인
stocks.chhong.kr {
	# SSL 인증서 자동 발급
	
	# 모든 요청을 stock_screener 서비스로 전달
	reverse_proxy stock_screener:8005 {
		fail_duration 10s
		max_fails 3
	}
}

# 메인 도메인 - 프론트엔드는 Vercel, API는 백엔드
chhong.kr {
	# SSL 인증서 자동 발급
	
	# API 요청
	handle /api/* {
		reverse_proxy playground:8000 {
			fail_duration 10s
			max_fails 3
			health_uri /health
			health_interval 30s
		}
	}

	# WebSocket 요청
	handle /ws {
		reverse_proxy playground:8010 {
			header_up Upgrade {http.request.header.Upgrade}
			header_up Connection {http.request.header.Connection}
			header_up Sec-WebSocket-Key {http.request.header.Sec-WebSocket-Key}
			header_up Sec-WebSocket-Version {http.request.header.Sec-WebSocket-Version}
		}
	}

	# Health check
	handle /health {
		reverse_proxy playground:8000
	}
	
	# 프론트엔드는 Vercel에서 처리
	respond "PlayGround - Frontend at Vercel" 404
}

