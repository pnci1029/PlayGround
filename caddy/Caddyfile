# API 서브도메인 - 백엔드 + WebSocket (Contabo)
api.chhong.kr {
	# SSL 인증서 자동 발급 (HTTP Challenge)
	tls internal

	# WebSocket 요청
	handle /ws {
		reverse_proxy playground:8010 {
			header_up Upgrade {http.request.header.Upgrade}
			header_up Connection {http.request.header.Connection}
			header_up Sec-WebSocket-Key {http.request.header.Sec-WebSocket-Key}
			header_up Sec-WebSocket-Version {http.request.header.Sec-WebSocket-Version}
		}
	}

	# API 요청
	handle /api/* {
		reverse_proxy playground:8000 {
			fail_duration 10s
			max_fails 3
			health_uri /health
			health_interval 30s
		}
	}

	# Health check
	handle /health {
		reverse_proxy playground:8000
	}
}

# localhost (개발용)
localhost {
	# API 요청은 백엔드로
	handle_path /api/* {
		reverse_proxy playground:8000 {
			fail_duration 10s
			max_fails 3
			health_uri /health
			health_interval 30s
		}
	}

	# WebSocket 요청은 백엔드로
	handle /ws {
		reverse_proxy playground:8010 {
			header_up Upgrade {http.request.header.Upgrade}
			header_up Connection {http.request.header.Connection}
		}
	}

	# 프론트엔드는 Vercel로 배포됨 - API 전용 서버
	respond "PlayGround API Server" 404
}

# MoodBite API 서브도메인 (Contabo)
api.moodbite.chhong.kr {
	# SSL 인증서 자동 발급 (HTTP Challenge)
	tls internal

	# WebSocket 요청
	handle /ws {
		reverse_proxy moodbite:8084 {
			header_up Upgrade {http.request.header.Upgrade}
			header_up Connection {http.request.header.Connection}
			header_up Sec-WebSocket-Key {http.request.header.Sec-WebSocket-Key}
			header_up Sec-WebSocket-Version {http.request.header.Sec-WebSocket-Version}
		}
	}

	# API 요청
	handle /api/* {
		reverse_proxy moodbite:8082 {
			fail_duration 10s
			max_fails 3
		}
	}

	# Health check
	handle /health {
		reverse_proxy moodbite:8082
	}
}

# Trend 서브도메인
trend.chhong.kr, trend.localhost {
	# SSL 인증서 자동 발급 (HTTP Challenge)
	tls internal

	# API 요청은 백엔드로
	handle_path /api/* {
		reverse_proxy trend:8002 {
			fail_duration 10s
			max_fails 3
			health_uri /health
			health_interval 30s
		}
	}

	# WebSocket 요청은 백엔드로
	handle /ws {
		reverse_proxy trend:8012 {
			header_up Upgrade {http.request.header.Upgrade}
			header_up Connection {http.request.header.Connection}
		}
	}

	# 프론트엔드 없음 - API 전용 서버
	respond "Trend API Server" 404
}

# Blog 서브도메인
blog.chhong.kr, blog.localhost {
	# SSL 인증서 자동 발급 (HTTP Challenge)
	tls internal

	# API 요청은 백엔드로
	handle_path /api/* {
		reverse_proxy blog:8003 {
			fail_duration 10s
			max_fails 3
			health_uri /health
			health_interval 30s
		}
	}

	# WebSocket 요청은 백엔드로
	handle /ws {
		reverse_proxy blog:8013
	}

	# 프론트엔드 없음 - API 전용 서버
	respond "Blog API Server" 404
}

