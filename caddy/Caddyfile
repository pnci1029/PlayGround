# ── 보안 헤더 스니펫 (전 사이트 공통) ─────────────────────────────────
# 각 사이트 블록 안에서 `import security_headers` 로 적용한다.
#  - Strict-Transport-Security : HTTPS 강제(다운그레이드/스트립 방지)
#  - X-Content-Type-Options    : MIME 스니핑 차단
#  - X-Frame-Options           : 클릭재킹(iframe 삽입) 차단
#  - Referrer-Policy           : 외부로 전체 URL 유출 방지
#  - -Server                   : 서버 소프트웨어 노출 제거
# 주의: CSP 는 정적 프론트(salehero 등) 깨짐 위험이 있어 사이트별 튜닝 필요 → 여기 미포함.
(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}

# API 서브도메인 - 백엔드 + WebSocket (Contabo)
api.chhong.kr {
	import security_headers
	# SSL 인증서 자동 발급 (Let's Encrypt)

	# WebSocket 요청
	handle /ws {
		reverse_proxy playground:8010 {
			header_up Upgrade {http.request.header.Upgrade}
			header_up Connection {http.request.header.Connection}
			header_up Sec-WebSocket-Key {http.request.header.Sec-WebSocket-Key}
			header_up Sec-WebSocket-Version {http.request.header.Sec-WebSocket-Version}
		}
	}

	# API 요청
	handle /api/* {
		reverse_proxy playground:8000 {
			fail_duration 10s
			max_fails 3
			health_uri /health
			health_interval 30s
		}
	}

	# Health check
	handle /health {
		reverse_proxy playground:8000
	}
}

# localhost (개발용)
localhost {
	# API 요청은 백엔드로
	handle_path /api/* {
		reverse_proxy playground:8000 {
			fail_duration 10s
			max_fails 3
			health_uri /health
			health_interval 30s
		}
	}

	# WebSocket 요청은 백엔드로
	handle /ws {
		reverse_proxy playground:8010 {
			header_up Upgrade {http.request.header.Upgrade}
			header_up Connection {http.request.header.Connection}
		}
	}

	# 프론트엔드는 Vercel로 배포됨 - API 전용 서버
	respond "PlayGround API Server" 404
}

