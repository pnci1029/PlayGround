# Stock Screener API 서브도메인 (Contabo)
stock-api.chhong.kr {
	import security_headers
	# SSL 인증서 자동 발급 (Let's Encrypt)

	# 모든 요청을 stock_screener 백엔드로 전달
	reverse_proxy stock_screener:8005 {
		fail_duration 10s
		max_fails 3
	}
}

