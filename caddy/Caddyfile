# 메인 도메인 - Playground
chhong.kr, playground.chhong.kr {
	# API 요청은 백엔드로
	handle /api/* {
		reverse_proxy playground_backend:8000 {
			fail_duration 10s
			max_fails 3
			health_uri /health
			health_interval 30s
		}
	}
	
	# WebSocket 요청은 백엔드로
	handle /ws {
		reverse_proxy playground_backend:8010 {
			header_up Upgrade {http.request.header.Upgrade}
			header_up Connection {http.request.header.Connection}
		}
	}
	
	# 프론트엔드는 Vercel로 배포됨 - API 전용 서버
	respond "PlayGround API Server" 404
}

# localhost (개발용)
localhost {
	# API 요청은 백엔드로
	handle_path /api/* {
		reverse_proxy playground_backend:8000 {
			fail_duration 10s
			max_fails 3
			health_uri /health
			health_interval 30s
		}
	}
	
	# WebSocket 요청은 백엔드로
	handle /ws {
		reverse_proxy playground_backend:8010 {
			header_up Upgrade {http.request.header.Upgrade}
			header_up Connection {http.request.header.Connection}
		}
	}
	
	# 프론트엔드는 Vercel로 배포됨 - API 전용 서버  
	respond "PlayGround API Server" 404
}

# MoodBite 서브도메인
moodbite.chhong.kr, moodbite.localhost {
	# API 요청은 백엔드로
	handle /api/* {
		reverse_proxy moodbite_backend:8082
	}
	
	# WebSocket 요청은 백엔드로  
	handle /ws {
		reverse_proxy moodbite_backend:8084 {
			header_up Upgrade {http.request.header.Upgrade}
			header_up Connection {http.request.header.Connection}
		}
	}
	
	# 프론트엔드는 Vercel로 배포됨 - API 전용 서버
	respond "MoodBite API Server" 404
}

# Trend 서브도메인  
trend.chhong.kr, trend.localhost {
	# API 요청은 백엔드로
	handle_path /api/* {
		reverse_proxy trend_backend:8002 {
			fail_duration 10s
			max_fails 3
			health_uri /health
			health_interval 30s
		}
	}
	
	# WebSocket 요청은 백엔드로
	handle /ws {
		reverse_proxy trend_backend:8012 {
			header_up Upgrade {http.request.header.Upgrade}
			header_up Connection {http.request.header.Connection}
		}
	}
	
	# 프론트엔드 없음 - API 전용 서버
	respond "Trend API Server" 404
}

# Blog 서브도메인
blog.chhong.kr, blog.localhost {
	# API 요청은 백엔드로
	handle_path /api/* {
		reverse_proxy blog_backend:8003 {
			fail_duration 10s
			max_fails 3
			health_uri /health
			health_interval 30s
		}
	}
	
	# WebSocket 요청은 백엔드로
	handle /ws {
		reverse_proxy blog_backend:8013
	}
	
	# 프론트엔드 없음 - API 전용 서버
	respond "Blog API Server" 404
}

