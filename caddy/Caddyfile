# API 서브도메인 - 백엔드 + WebSocket (Contabo)
api.chhong.kr {
	# SSL 인증서 자동 발급 (Let's Encrypt)

	# WebSocket 요청
	handle /ws {
		reverse_proxy playground:8010 {
			header_up Upgrade {http.request.header.Upgrade}
			header_up Connection {http.request.header.Connection}
			header_up Sec-WebSocket-Key {http.request.header.Sec-WebSocket-Key}
			header_up Sec-WebSocket-Version {http.request.header.Sec-WebSocket-Version}
		}
	}

	# API 요청
	handle /api/* {
		reverse_proxy playground:8000 {
			fail_duration 10s
			max_fails 3
			health_uri /health
			health_interval 30s
		}
	}

	# Health check
	handle /health {
		reverse_proxy playground:8000
	}
}

# localhost (개발용)
localhost {
	# API 요청은 백엔드로
	handle_path /api/* {
		reverse_proxy playground:8000 {
			fail_duration 10s
			max_fails 3
			health_uri /health
			health_interval 30s
		}
	}

	# WebSocket 요청은 백엔드로
	handle /ws {
		reverse_proxy playground:8010 {
			header_up Upgrade {http.request.header.Upgrade}
			header_up Connection {http.request.header.Connection}
		}
	}

	# 프론트엔드는 Vercel로 배포됨 - API 전용 서버
	respond "PlayGround API Server" 404
}

# MoodBite API 서브도메인 (Contabo)
moodbite-api.chhong.kr {
	# SSL 인증서 자동 발급 (Let's Encrypt)

	# WebSocket 요청
	handle /ws {
		reverse_proxy moodbite:8084 {
			header_up Upgrade {http.request.header.Upgrade}
			header_up Connection {http.request.header.Connection}
			header_up Sec-WebSocket-Key {http.request.header.Sec-WebSocket-Key}
			header_up Sec-WebSocket-Version {http.request.header.Sec-WebSocket-Version}
		}
	}

	# API 요청
	handle /api/* {
		reverse_proxy moodbite:8082 {
			fail_duration 10s
			max_fails 3
		}
	}

	# Health check
	handle /health {
		reverse_proxy moodbite:8082
	}
}

# Trend 서브도메인
trend.chhong.kr, trend.localhost {
	# SSL 인증서 자동 발급 (HTTP Challenge)
	tls internal

	# API 요청은 백엔드로
	handle_path /api/* {
		reverse_proxy trend:8002 {
			fail_duration 10s
			max_fails 3
			health_uri /health
			health_interval 30s
		}
	}

	# WebSocket 요청은 백엔드로
	handle /ws {
		reverse_proxy trend:8012 {
			header_up Upgrade {http.request.header.Upgrade}
			header_up Connection {http.request.header.Connection}
		}
	}

	# 프론트엔드 없음 - API 전용 서버
	respond "Trend API Server" 404
}

# Blog 서브도메인
blog.chhong.kr, blog.localhost {
	# SSL 인증서 자동 발급 (HTTP Challenge)
	tls internal

	# API 요청은 백엔드로
	handle_path /api/* {
		reverse_proxy blog:8003 {
			fail_duration 10s
			max_fails 3
			health_uri /health
			health_interval 30s
		}
	}

	# WebSocket 요청은 백엔드로
	handle /ws {
		reverse_proxy blog:8013
	}

	# 프론트엔드 없음 - API 전용 서버
	respond "Blog API Server" 404
}

# SaleHero 프론트엔드 서빙
salehero.kr, www.salehero.kr {
	# SSL 인증서 자동 발급
	
	# API 요청은 백엔드로
	handle /api/* {
		reverse_proxy salehero-container:8880 {
			fail_duration 10s
			max_fails 3
		}
	}
	
	# 정적 파일 서빙 (프론트엔드)
	handle {
		root * /usr/share/nginx/html
		file_server
		try_files {path} /index.html
	}
}

# SaleHero n8n 서브도메인
n8n.salehero.kr {
	# SSL 인증서 자동 발급
	
	# n8n 웹 인터페이스
	reverse_proxy n8n:5678 {
		fail_duration 10s
		max_fails 3
	}
}

# 404 전용 서브도메인
404.chhong.kr {
	# SSL 인증서 자동 발급
	
	# 404 페이지 서빙
	handle {
		root * /usr/share/caddy/404
		file_server
		try_files {path} /index.html
	}
}

# 지원하지 않는 서브도메인에 대한 fallback - 404 서브도메인으로 리다이렉트
*.chhong.kr {
	redir https://404.chhong.kr{uri} 302
}
