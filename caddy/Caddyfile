# 404 전용 서브도메인
404.chhong.kr {
	import security_headers
	# SSL 인증서 자동 발급

	# 404 페이지 서빙
	handle {
		root * /usr/share/caddy/404
		file_server
		try_files {path} /index.html
	}
}

