# 메인 도메인 - Playground
chhong.kr, playground.chhong.kr {
	# API 요청은 백엔드로
	handle /api/* {
		reverse_proxy playground_backend:8000
	}
	
	# WebSocket 요청은 백엔드로
	handle /ws {
		reverse_proxy playground_backend:8010 {
			header_up Upgrade {http.request.header.Upgrade}
			header_up Connection {http.request.header.Connection}
		}
	}
	
	# 나머지는 프론트엔드로
	reverse_proxy playground_frontend:3000
}

# localhost (개발용)
localhost {
	# API 요청은 백엔드로
	handle_path /api/* {
		reverse_proxy playground_backend:8000
	}
	
	# WebSocket 요청은 백엔드로
	handle /ws {
		reverse_proxy playground_backend:8010 {
			header_up Upgrade {http.request.header.Upgrade}
			header_up Connection {http.request.header.Connection}
		}
	}
	
	# 나머지는 프론트엔드로
	reverse_proxy playground_frontend:3000
}

# MoodBite 서브도메인
moodbite.chhong.kr, moodbite.localhost {
	# API 요청은 백엔드로
	handle /api/* {
		reverse_proxy moodbite_backend:8082
	}
	
	# WebSocket 요청은 백엔드로  
	handle /ws {
		reverse_proxy moodbite_backend:8084 {
			header_up Upgrade {http.request.header.Upgrade}
			header_up Connection {http.request.header.Connection}
		}
	}
	
	# 나머지는 프론트엔드로
	reverse_proxy moodbite_frontend:3000
}

# Trend 서브도메인  
