# ⚠️ story_be는 프로젝트별 .env를 두지 않습니다.
# 모든 환경변수/비밀값은 모노레포 루트 .env 한 곳에서 STORY_ 접두어로 관리합니다.
#   → PlayGround/.env  (gitignore 처리됨)
#
# 루트 .env 에 들어가는 story 항목 (예시):
#
#   # ── story (AI 소설 생성) ──
#   STORY_PORT=8004
#   STORY_DB_DRIVER=pglite                 # 로컬=pglite / 운영=pg
#   STORY_PGLITE_DATA_DIR=./.pgdata         # 로컬 임베디드 DB 저장 폴더
#   STORY_DAILY_LIMIT=3
#   STORY_OPENAI_API_KEY=sk-...
#   STORY_OPENAI_MODEL=gpt-4.1-mini
#   STORY_OPENAI_MODERATION_MODEL=omni-moderation-latest
#
# 운영(pg) 모드에서 DB 접속은 공용 POSTGRES_DB/POSTGRES_USER/POSTGRES_PASSWORD 를 재사용하고,
# host/port/schema 만 STORY_DB_HOST / STORY_DB_PORT / STORY_DB_SCHEMA 로 지정합니다.
